# Dhan Broker API
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token

# OpenAlgo (self-hosted)
OPENALGO_URL=http://localhost:5000
OPENALGO_API_KEY=your_openalgo_api_key

# Supabase (shared with review-app)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# LLM Provider for TradingAgents
LLM_PROVIDER=openai  # openai | anthropic | xai
XAI_API_KEY=your_xai_key
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key

# Trading Parameters
PAPER_TRADING=true
DAILY_CAP_INR=840
PER_TRADE_CAP_INR=168
MAX_TRADES_PER_DAY=5
STOP_LOSS_PERCENT=1.0
DAILY_MAX_LOSS_PERCENT=3.0
TARGET_PROFIT_PERCENT=1.5
DAILY_TARGET_PERCENT=5.0
RSI_OVERSOLD=30
RSI_PERIOD=14
SCAN_INTERVAL_SECONDS=60
CONSECUTIVE_LOSS_LIMIT=3

# Market Hours (IST)
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
SCAN_STOP=15:15
FORCE_CLOSE=15:25

# FastAPI
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8100
